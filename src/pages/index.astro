---
import '../styles/global.css'
import PauseIcon from '@lucide/astro/icons/pause'
import PlayIcon from '@lucide/astro/icons/play'
import SkipBackIcon from '@lucide/astro/icons/skip-back'
import SkipForwardIcon from '@lucide/astro/icons/skip-forward'

const pageTitle = 'Kif - GIF meme editor'
const pageDescription =
  'Create and edit GIF captions with draggable text, frame-based visibility, playback controls, and export support.'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preload" href="/impact.ttf" as="font" type="font/ttf" crossorigin />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={pageDescription} />
    <meta name="application-name" content="Kif" />
    <meta name="theme-color" content="#18181b" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Kif" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content="/favicon.ico" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main class="mx-auto flex w-full max-w-[800px] flex-col gap-6 px-4 py-6 sm:px-6">
      <h1 class="text-3xl font-semibold tracking-tight">Kif - Annotate gif memes</h1>

      <div id="kif-file-picker-shell" class="relative block w-full">
        <div class="pointer-events-none absolute inset-x-6 top-6 space-y-1">
          <label for="kif-file-picker" class="block text-lg font-medium text-zinc-900"> Click to choose a GIF </label>
          <p class="text-sm text-zinc-600">Or drop one here.</p>
        </div>

        <input
          id="kif-file-picker"
          type="file"
          accept="image/gif"
          class="block w-full cursor-pointer rounded-3xl border border-dashed border-zinc-300 bg-zinc-50 px-6 pb-6 pt-24 text-sm text-zinc-700 transition hover:border-sky-400 hover:bg-sky-50 file:mr-4 file:cursor-pointer file:rounded-lg file:border-0 file:bg-zinc-900 file:px-4 file:py-2 file:text-sm file:font-medium file:text-white hover:file:bg-zinc-700"
        />
      </div>

      <div id="preview-viewport" class="w-full overflow-hidden rounded-2xl border border-zinc-200 bg-zinc-50">
        <div id="preview-viewport-inner" class="relative flex min-h-80 w-full items-center justify-center p-4 sm:p-6">
          <div class="absolute left-4 top-4 z-20 flex flex-wrap gap-1.5">
            <button
              id="toggle-playback-button"
              type="button"
              aria-label="Pause preview"
              class="flex h-8 w-8 items-center justify-center rounded-lg border border-sky-200 bg-white/95 text-sm leading-none text-sky-700 shadow-sm backdrop-blur-sm transition hover:bg-sky-50 disabled:cursor-not-allowed disabled:border-zinc-200 disabled:bg-white/80 disabled:text-zinc-400"
            >
              <span id="playback-icon-pause">
                <PauseIcon class="h-4 w-4" stroke-width={2.25} />
              </span>
              <span id="playback-icon-play" class="hidden">
                <PlayIcon class="h-4 w-4" stroke-width={2.25} />
              </span>
            </button>
            <button
              id="step-backward-button"
              type="button"
              aria-label="Previous frame"
              class="flex h-8 w-8 items-center justify-center rounded-lg border border-zinc-200 bg-white/95 text-sm leading-none text-zinc-700 shadow-sm backdrop-blur-sm transition hover:bg-zinc-50 disabled:cursor-not-allowed disabled:border-zinc-200 disabled:bg-white/80 disabled:text-zinc-400"
            >
              <span>
                <SkipBackIcon class="h-4 w-4" stroke-width={2.25} />
              </span>
            </button>
            <button
              id="step-forward-button"
              type="button"
              aria-label="Next frame"
              class="flex h-8 w-8 items-center justify-center rounded-lg border border-zinc-200 bg-white/95 text-sm leading-none text-zinc-700 shadow-sm backdrop-blur-sm transition hover:bg-zinc-50 disabled:cursor-not-allowed disabled:border-zinc-200 disabled:bg-white/80 disabled:text-zinc-400"
            >
              <span>
                <SkipForwardIcon class="h-4 w-4" stroke-width={2.25} />
              </span>
            </button>
          </div>
          <div id="preview-stage" class="relative">
            <div id="canvas-stack-shell" class="inline-block origin-top-left pt-4 pr-6 pb-5">
              <div id="canvas-stack" class="relative shrink-0">
                <div
                  id="gif-width"
                  class="pointer-events-none absolute inset-x-0 -top-4 flex justify-center text-xs font-medium text-zinc-500"
                >
                </div>
                <div
                  id="gif-height"
                  class="pointer-events-none absolute left-full top-1/2 -translate-x-2 -translate-y-1/2 rotate-90 whitespace-nowrap text-xs font-medium text-zinc-500"
                >
                </div>
                <div
                  id="gif-frame-counter"
                  class="pointer-events-none absolute inset-x-0 -bottom-5 flex justify-center text-xs font-medium text-zinc-500"
                >
                </div>
                <canvas id="da-canvas" class="block border border-zinc-200 bg-white shadow-sm" width="240" height="240"
                ></canvas>
                <canvas id="fabric-canvas" class="absolute inset-0" width="240" height="240"></canvas>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div id="preview-timeline-shell" class="overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm">
        <div class="border-b border-zinc-200 px-4 py-2 text-xs font-medium uppercase tracking-wide text-zinc-500">
          Timeline
        </div>
        <div id="preview-timeline" class="relative h-18 bg-zinc-200">
          <div id="preview-timeline-thumbnails" class="absolute inset-0 flex items-stretch gap-px"></div>
          <div
            id="preview-timeline-indicator"
            class="pointer-events-none absolute inset-y-0 left-0 z-20 -ml-px w-0.5 bg-sky-500"
          >
          </div>
          <input
            id="preview-timeline-slider"
            type="range"
            min="0"
            max="0"
            value="0"
            step="1"
            aria-label="Preview timeline"
            class="kif-timeline-slider absolute inset-0 z-30 h-full w-full cursor-ew-resize bg-transparent disabled:cursor-not-allowed"
          />
        </div>
      </div>
      <section class="space-y-4 rounded-2xl border border-zinc-200 bg-white p-4 shadow-sm">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold text-zinc-900">Overlays</h2>
            <p class="text-sm text-zinc-600">Add or edit text and picture in the gif.</p>
          </div>
          <div class="flex items-center gap-2">
            <button
              id="add-picture-node"
              type="button"
              class="rounded-xl border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-700 transition hover:border-zinc-400 hover:bg-zinc-100"
            >
              Add picture
            </button>
            <button
              id="add-text-node"
              type="button"
              class="rounded-xl bg-zinc-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-zinc-700"
            >
              Add text
            </button>
          </div>
        </div>
        <div id="overlay-node-controls" class="space-y-3 text-sm text-zinc-600"></div>
      </section>
      <button
        id="export-gif-button"
        type="button"
        class="w-full rounded-2xl bg-green-600 px-6 py-4 text-lg font-semibold text-white shadow-sm transition hover:bg-green-500 disabled:cursor-not-allowed disabled:bg-zinc-300"
      >
        Export
      </button>
      <dialog id="exported-gif-dialog" class="max-w-[min(90vw,900px)] rounded-2xl p-0 shadow-xl backdrop:bg-black/50">
        <div class="space-y-4 p-4 sm:p-6">
          <div class="flex items-center justify-between gap-4">
            <h2 class="text-lg font-semibold text-zinc-900">Exported GIF</h2>
            <form method="dialog">
              <button
                type="submit"
                class="rounded-lg border border-zinc-300 bg-white px-3 py-1.5 text-sm font-medium text-zinc-700 transition hover:border-zinc-400 hover:bg-zinc-100"
              >
                Close
              </button>
            </form>
          </div>
          <img
            id="exported-gif-image"
            alt="Exported GIF preview"
            class="mx-auto max-h-[70vh] max-w-full border border-zinc-200 bg-zinc-50"
          />
          <a
            id="exported-gif-download"
            download="kif-export.gif"
            class="inline-flex rounded-xl bg-zinc-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-zinc-700"
          >
            Download GIF
          </a>
        </div>
      </dialog>
      <script src="@editor/editor.ts"></script>
      <script src="@editor/controls.ts"></script>
      <script src="@editor/drop.ts"></script>
    </main>
  </body>
</html>
